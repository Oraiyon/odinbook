// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  username         String    @unique @db.VarChar(10)
  password         String    @db.VarChar(10)
  FollowedBy       Follow[]  @relation("FollowedBy")
  Following        Follow[]  @relation("Following")
  SentRequests     Request[] @relation("SentRequests")
  ReceivedRequests Request[] @relation("ReceivedRequests")
  WrittenPosts     Post[]    @relation("WrittenPosts")
  LikedPosts       Post[]    @relation("LikedPosts")
  Comments         Comment[]

  @@map("users")
}

model Follow {
  followedBy   User   @relation("FollowedBy", fields: [followedById], references: [id])
  followedById String
  following    User   @relation("Following", fields: [followingId], references: [id])
  followingId  String

  @@id([followedById, followingId])
  @@map("follows")
}

model Request {
  id         String @id @default(uuid())
  sender     User   @relation("SentRequests", fields: [senderId], references: [id])
  senderId   String
  receiver   User   @relation("ReceivedRequests", fields: [receiverId], references: [id])
  receiverId String

  @@map("requests")
}

model Post {
  id        String    @id @default(uuid())
  author    User      @relation("WrittenPosts", fields: [authorId], references: [id])
  authorId  String
  text      String    @db.VarChar(100)
  likedBy   User?     @relation("LikedPosts", fields: [likedById], references: [id])
  likedById String?
  Comments  Comment[]

  @@map("posts")
}

model Comment {
  id       String    @id @default(uuid())
  author   User      @relation(fields: [authorId], references: [id])
  authorId String
  text     String    @db.VarChar(100)
  post     Post      @relation(fields: [postId], references: [id])
  postId   String
  Replies  Comment[] @relation("Reply")
  reply    Comment   @relation("Reply", fields: [replyId], references: [id])
  replyId  String

  @@map("comments")
}
